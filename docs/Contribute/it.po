# This content is from "USAGE_webui.md", line 36
msgctxt "chunk_104D91B6"
msgid "- `PDF2ZH_LANG_FROM`: Sets the source language. Defaults to \"English\".\n- `PDF2ZH_LANG_TO`: Sets the target language. Defaults to \"Simplified Chinese\".\n"
msgstr "- `PDF2ZH_LANG_FROM`: Imposta la lingua di origine. Predefinito è \"English\".\n- `PDF2ZH_LANG_TO`: Imposta la lingua di destinazione. Predefinito è \"Simplified Chinese\".\n"

