# This content is from "Documentation-of-Translation-Services.md", line 5
msgctxt "chunk_7775DA81"
msgid "### Viewing Available Translate Services via Command Line\n"
msgstr "### Visualización de servicios de traducción disponibles a través de la Línea de comandos\n"

# This content is from "Documentation-of-Translation-Services.md", line 7
msgctxt "chunk_4919DFD2"
msgid "You can confirm the available translate services and their usage by printing the help message in the command line.\n"
msgstr "Puedes confirmar los servicios de traducción disponibles y su uso imprimiendo el mensaje de ayuda en la línea de comandos.\n"

# This content is from "Documentation-of-Translation-Services.md", line 13
msgctxt "chunk_7935E690"
msgid "At the end of the help message, you can view detailed information about the different translation services.\n"
msgstr "Al final del mensaje de ayuda, puedes ver información detallada sobre los diferentes servicios de traducción.\n"

